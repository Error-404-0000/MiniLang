<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="MiniLang.Studio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    RequestedTheme="Dark"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AppBackgroundColor">#10151D</Color>
            <Color x:Key="PanelBackgroundColor">#151C27</Color>
            <Color x:Key="PanelHeaderColor">#1C2531</Color>
            <Color x:Key="PanelBorderColor">#273445</Color>
            <Color x:Key="AccentColor">#46A4FF</Color>
            <Color x:Key="AccentSoftColor">#203754</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
            <SolidColorBrush x:Key="PanelHeaderBrush" Color="{StaticResource PanelHeaderColor}" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />

            <x:Double x:Key="UiFontSize">12</x:Double>
            <x:Double x:Key="CodeFontSize">13.5</x:Double>

            <Style x:Key="PanelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="{StaticResource UiFontSize}" />
                <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            </Style>

            <Style x:Key="PanelContainerStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="PanelHeaderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PanelHeaderBrush}" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="CornerRadius" Value="10,10,0,0" />
            </Style>

            <Style x:Key="CodeBlockStyle" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="Cascadia Code" />
                <Setter Property="FontSize" Value="{StaticResource CodeFontSize}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
